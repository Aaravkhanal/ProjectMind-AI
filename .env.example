# ─────────────────────────────────────────────
# ProjectMind AI — Environment Configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Options: openai | anthropic | nvidia | ollama
LLM_PROVIDER=openai

# API key for your chosen provider
API_KEY=your-api-key-here

# Optional: custom base URL (for proxies, self-hosted, or NVIDIA NIM)
# API_URL=https://integrate.api.nvidia.com/v1

# Model names — override to use any model your provider supports
CODE_MODEL=gpt-4o-mini
CONVERSATION_MODEL=gpt-4o-mini

# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# NVIDIA NIM (only needed if LLM_PROVIDER=nvidia)
# NVIDIA_API_URL=https://integrate.api.nvidia.com/v1

# ── GitHub Integration ────────────────────────
# Personal Access Token with repo + pull_requests scope
# GITHUB_TOKEN=ghp_...

# ── GitLab Integration ───────────────────────
# Personal Access Token with api scope
# GITLAB_TOKEN=glpat-...
# GIT_BASE_URL=https://gitlab.com

# ── Token Savings Dashboard ───────────────────
# Adjust to match your actual LLM pricing (per million tokens)
# Default: GPT-4o input = $5.00/1M tokens
# Claude Sonnet 3.5 = $3.00, GPT-4o-mini = $0.15, Ollama = $0.00
# PM_PRICE_PER_MILLION_TOKENS=5.0

# ── API Server ────────────────────────────────
PORT=8000
ENV=development
LOG_LEVEL=info

# ── Memory / Storage ─────────────────────────
# These are relative to the project being analyzed — usually leave as default
DB_PATH=.projectmind/memory.db
COLLECTION_NAME=projectmind
